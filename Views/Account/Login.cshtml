@model AddressManager.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Entrar";
    Layout = "_AuthLayout";
}

<div class="auth-card reveal">
    <div class="auth-logo">
        <span class="brand-mark">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 21s7-6.04 7-11a7 7 0 1 0-14 0c0 4.96 7 11 7 11Z" stroke="#fff" stroke-width="1.7" stroke-linejoin="round"/>
                <circle cx="12" cy="10" r="2.3" fill="#fff"/>
            </svg>
        </span>
        <b>AddressManager</b>
    </div>

    <h1>Acessar sua conta</h1>
    <p class="sub">Informe suas credenciais para gerenciar seus endereços.</p>

    <form asp-action="Login" method="post" novalidate>
        <input type="hidden" asp-for="ReturnUrl" />
        <div asp-validation-summary="ModelOnly" class="alert alert--danger" data-vs></div>

        <div class="field">
            <label asp-for="Login" class="label"></label>
            <input asp-for="Login" class="input" autocomplete="username" placeholder="seu usuário" autofocus />
            <span asp-validation-for="Login" class="field-error"></span>
        </div>

        <div class="field">
            <label asp-for="Senha" class="label"></label>
            <div class="pw-wrap">
                <input asp-for="Senha" class="input" autocomplete="current-password" placeholder="••••••••" style="padding-right:2.6rem;" />
                <button type="button" class="pw-toggle" data-pw-toggle="Senha" aria-label="Mostrar senha">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="2.7" stroke="currentColor" stroke-width="1.6"/></svg>
                </button>
            </div>
            <span asp-validation-for="Senha" class="field-error"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-block" style="margin-top:.4rem;">Entrar</button>
    </form>

    <div class="demo-creds">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 9v4m0 3h.01M10.3 3.9 2.4 18a2 2 0 0 0 1.7 3h15.8a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>Demonstração — usuário <code>admin</code> · senha <code>admin123</code></span>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
