@model ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<div class="error-state reveal">
    <div class="error-code">500</div>
    <h1>Ocorreu um erro.</h1>
    <p>Não foi possível processar a sua solicitação. Tente novamente em instantes — se o problema persistir, volte ao início.</p>

    @if (Model.ShowRequestId)
    {
        <p class="error-id">ID da requisição: <code>@Model.RequestId</code></p>
    }

    <div style="margin-top:1.5rem;">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Voltar ao início</a>
    </div>
</div>
