@model AddressManager.ViewModels.EnderecoViewModel
@{
    ViewData["Title"] = "Novo endereço";
}

<h1 class="h3 mb-3">Novo endereço</h1>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <partial name="_FormFields" model="Model" />

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Salvar</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/viacep.js" asp-append-version="true"></script>
}
