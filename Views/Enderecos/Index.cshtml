@model IEnumerable<AddressManager.Models.Endereco>
@{
    ViewData["Title"] = "Meus Endereços";
    var lista = Model.ToList();
    var totalCidades = lista.Select(e => e.Cidade?.Trim().ToLowerInvariant()).Distinct().Count();
    var totalUfs = lista.Select(e => e.UF?.Trim().ToUpperInvariant()).Distinct().Count();
}

<div class="page-head reveal">
    <div>
        <h1>Meus Endereços</h1>
        <p class="sub">Endereços vinculados à sua conta.</p>
    </div>
    <div class="head-actions">
        @if (lista.Any())
        {
            <a class="btn btn-secondary" asp-action="ExportarCsv">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3v12m0 0-4-4m4 4 4-4M5 21h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Exportar CSV
            </a>
        }
        <a class="btn btn-primary" asp-action="Create">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            Novo endereço
        </a>
    </div>
</div>

@if (!lista.Any())
{
    <div class="card reveal">
        <div class="empty">
            <div class="empty-art">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9.5 10h5M12 7.5v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Nenhum endereço cadastrado</h3>
            <p>Comece adicionando seu primeiro endereço. Com o CEP, preenchemos os demais campos para você.</p>
            <a class="btn btn-primary" asp-action="Create">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                Cadastrar endereço
            </a>
        </div>
    </div>
}
else
{
    <div class="summary reveal">
        <div class="cell">
            <div class="s-label"><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.1" stroke="currentColor" stroke-width="1.6"/></svg> Endereços</div>
            <div class="s-value">@lista.Count</div>
        </div>
        <div class="cell">
            <div class="s-label"><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 21V9l8-5 8 5v12M9 21v-6h6v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg> Cidades</div>
            <div class="s-value">@totalCidades</div>
        </div>
        <div class="cell">
            <div class="s-label"><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6 9 4l6 2 6-2v14l-6 2-6-2-6 2V6Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg> Estados</div>
            <div class="s-value">@totalUfs</div>
        </div>
    </div>

    <div class="toolbar reveal" style="animation-delay:.04s">
        <div class="search">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.7"/><path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
            <input type="search" id="tableSearch" placeholder="Buscar por rua, número, bairro, cidade, UF ou CEP…" aria-label="Buscar endereços" autocomplete="off" data-search-input data-search-target="addrTable" />
        </div>
        <span class="result-count" id="resultCount" role="status" aria-live="polite">@lista.Count registro@(lista.Count == 1 ? "" : "s")</span>
    </div>

    <div class="table-card address-list reveal" style="animation-delay:.06s">
        <div class="scroll-x">
            <table class="table address-table" id="addrTable">
                <thead>
                    <tr>
                        <th>CEP</th>
                        <th>Logradouro</th>
                        <th>Nº</th>
                        <th>Complemento</th>
                        <th>Bairro</th>
                        <th>Cidade</th>
                        <th>UF</th>
                        <th class="t-right">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var endereco in lista)
                    {
                        <tr data-row>
                            <td data-label="CEP"><span class="cep">@endereco.CEP</span></td>
                            <td class="primary-cell" data-label="Logradouro">@endereco.Logradouro</td>
                            <td class="t-num" data-label="Número">@endereco.Numero</td>
                            <td data-label="Complemento">@(string.IsNullOrWhiteSpace(endereco.Complemento) ? Html.Raw("<span class=\"dash\">—</span>") : (object)endereco.Complemento)</td>
                            <td data-label="Bairro">@endereco.Bairro</td>
                            <td data-label="Cidade">@endereco.Cidade</td>
                            <td data-label="UF"><span class="badge-uf">@endereco.UF</span></td>
                            <td class="t-right" data-label="Ações">
                                <span class="actions">
                                    <a class="icon-btn" asp-action="Edit" asp-route-id="@endereco.Id" title="Editar" aria-label="Editar endereço">
                                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h4L18.5 9.5a2 2 0 0 0 0-2.8l-1.2-1.2a2 2 0 0 0-2.8 0L4 16v4Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="m13.5 6.5 4 4" stroke="currentColor" stroke-width="1.6"/></svg>
                                    </a>
                                    <button type="button" class="icon-btn danger" title="Excluir" aria-label="Excluir endereço"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal"
                                            data-id="@endereco.Id"
                                            data-logradouro="@endereco.Logradouro"
                                            data-numero="@endereco.Numero"
                                            data-cidade="@endereco.Cidade"
                                            data-uf="@endereco.UF"
                                            data-cep="@endereco.CEP">
                                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 7h14M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2m1 0v12a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2V7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </button>
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="no-results" id="noResults" hidden>
            <p class="muted">Nenhum endereço corresponde à sua busca.</p>
        </div>
    </div>

    <style>
        /* Alinhamento confortável e responsivo dos botões do modal de exclusão. */
        #deleteModal .modal-footer { gap: .5rem; }
        #deleteModal .modal-footer > * { margin: 0; }
        #deleteModal .modal-footer .btn { min-width: 9rem; }
        @@media (max-width: 480px) {
            #deleteModal .modal-footer { flex-direction: column-reverse; align-items: stretch; }
            #deleteModal .modal-footer .btn { width: 100%; min-width: 0; }
        }
    </style>

    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="deleteModalLabel">Excluir endereço</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <form id="deleteForm" method="post" data-action-base="@Url.Action("Delete", "Enderecos")">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <p class="mb-3">Deseja realmente excluir este endereço? Esta ação não pode ser desfeita.</p>
                        <div class="border rounded-3 p-3">
                            <div class="fw-semibold mb-1" id="dm-rua"></div>
                            <div class="muted mb-2" id="dm-local"></div>
                            <span class="cep" id="dm-cep"></span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 7h14M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2m1 0v12a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2V7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            Excluir endereço
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        (function () {
            "use strict";
            var modal = document.getElementById("deleteModal");
            if (!modal) return;

            var form = document.getElementById("deleteForm");
            var elRua = document.getElementById("dm-rua");
            var elLocal = document.getElementById("dm-local");
            var elCep = document.getElementById("dm-cep");

            // Ao abrir, preenche o resumo e aponta o form para o endereço escolhido.
            modal.addEventListener("show.bs.modal", function (event) {
                var btn = event.relatedTarget;
                if (!btn) return;
                var d = btn.dataset;

                elRua.textContent = (d.logradouro || "Endereço") + (d.numero ? ", " + d.numero : "");
                elLocal.textContent = [d.cidade, d.uf].filter(Boolean).join(" / ");
                elCep.textContent = d.cep || "";

                if (form && form.dataset.actionBase && d.id) {
                    form.action = form.dataset.actionBase + "/" + encodeURIComponent(d.id);
                }
            });
        })();
    </script>
}
