@model IReadOnlyList<AddressManager.Models.Endereco>
@{
    ViewData["Title"] = "Início";
    var totalCidades = Model
        .Select(e => e.Cidade?.Trim().ToLowerInvariant())
        .Where(c => !string.IsNullOrWhiteSpace(c))
        .Distinct()
        .Count();
    var totalEstados = Model
        .Select(e => e.UF?.Trim().ToUpperInvariant())
        .Where(uf => !string.IsNullOrWhiteSpace(uf))
        .Distinct()
        .Count();
    var ultimoCadastro = Model.OrderByDescending(e => e.Id).FirstOrDefault();
    var ultimosEnderecos = Model.OrderByDescending(e => e.Id).Take(4).ToList();
}

<section class="dashboard-hero reveal">
    <div class="dashboard-intro">
        <h1>Seu painel de endereços</h1>
        <p>Gerencie seus cadastros, encontre informações rapidamente e exporte seus dados quando precisar.</p>
    </div>
    <div class="dashboard-actions">
        <a class="btn btn-primary" asp-controller="Enderecos" asp-action="Create">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            Novo endereço
        </a>
        <a class="btn btn-secondary" asp-controller="Enderecos" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M8 6h12M8 12h12M8 18h12M4 6h.01M4 12h.01M4 18h.01" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
            Ver endereços
        </a>
    </div>
</section>

<section class="dashboard-metrics reveal" aria-label="Resumo dos endereços" style="animation-delay:.04s">
    <article class="metric-card">
        <span class="metric-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.1" stroke="currentColor" stroke-width="1.6"/></svg>
        </span>
        <span class="metric-content">
            <span>Total de endereços</span>
            <strong>@Model.Count</strong>
            <small>@(Model.Count == 1 ? "cadastro ativo" : "cadastros ativos")</small>
        </span>
    </article>
    <article class="metric-card">
        <span class="metric-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 21V9l8-5 8 5v12M9 21v-6h6v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="metric-content">
            <span>Cidades cadastradas</span>
            <strong>@totalCidades</strong>
            <small>em @totalEstados estado@(totalEstados == 1 ? "" : "s")</small>
        </span>
    </article>
    <article class="metric-card metric-card--wide">
        <span class="metric-icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8v4l2.5 1.5M21 12a9 9 0 1 1-3-6.7M21 4v5h-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="metric-content">
            <span>Último cadastro</span>
            @if (ultimoCadastro is null)
            {
                <strong class="metric-empty">Nenhum ainda</strong>
                <small>Cadastre seu primeiro endereço</small>
            }
            else
            {
                <strong class="metric-address">@ultimoCadastro.Logradouro, @ultimoCadastro.Numero</strong>
                <small>@ultimoCadastro.Cidade / @ultimoCadastro.UF</small>
            }
        </span>
    </article>
</section>

<div class="dashboard-content">
    <section class="dashboard-panel recent-panel reveal" style="animation-delay:.08s">
        <div class="panel-head">
            <div>
                <span class="eyebrow">Visão rápida</span>
                <h2>Últimos endereços</h2>
            </div>
            @if (Model.Any())
            {
                <a class="panel-link" asp-controller="Enderecos" asp-action="Index">
                    Ver todos
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m9 18 6-6-6-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            }
        </div>

        @if (!ultimosEnderecos.Any())
        {
            <div class="dashboard-empty">
                <span class="empty-art">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9.5 10h5M12 7.5v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </span>
                <div>
                    <h3>Nenhum endereço cadastrado</h3>
                    <p>Adicione um endereço para acompanhar seus cadastros por aqui.</p>
                </div>
                <a class="btn btn-primary btn-sm" asp-controller="Enderecos" asp-action="Create">Cadastrar agora</a>
            </div>
        }
        else
        {
            <div class="recent-addresses">
                @foreach (var endereco in ultimosEnderecos)
                {
                    <article class="recent-address">
                        <span class="recent-marker">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="12" cy="10" r="2" stroke="currentColor" stroke-width="1.6"/></svg>
                        </span>
                        <div class="recent-main">
                            <strong>@endereco.Logradouro, @endereco.Numero</strong>
                            <span>@endereco.Bairro · @endereco.Cidade / @endereco.UF</span>
                        </div>
                        <span class="recent-cep">@endereco.CEP</span>
                        <a class="icon-btn" asp-controller="Enderecos" asp-action="Edit" asp-route-id="@endereco.Id" title="Editar" aria-label="Editar @endereco.Logradouro">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h4L18.5 9.5a2 2 0 0 0 0-2.8l-1.2-1.2a2 2 0 0 0-2.8 0L4 16v4Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="m13.5 6.5 4 4" stroke="currentColor" stroke-width="1.6"/></svg>
                        </a>
                    </article>
                }
            </div>
        }
    </section>

    <aside class="dashboard-side">
        <section class="dashboard-panel workflow-panel reveal" style="animation-delay:.1s">
            <div class="panel-head">
                <div>
                    <span class="eyebrow">Fluxo simples</span>
                    <h2>Como funciona</h2>
                </div>
            </div>
            <ol class="workflow-steps">
                <li>
                    <span class="step-number">01</span>
                    <div><strong>Informe o CEP</strong><span>Comece digitando os oito números.</span></div>
                </li>
                <li>
                    <span class="step-number">02</span>
                    <div><strong>Preenchimento automático</strong><span>O ViaCEP completa rua, bairro e cidade.</span></div>
                </li>
                <li>
                    <span class="step-number">03</span>
                    <div><strong>Salve ou exporte</strong><span>Gerencie tudo e baixe em CSV.</span></div>
                </li>
            </ol>
        </section>

        <a class="export-callout reveal" asp-controller="Enderecos" asp-action="ExportarCsv" style="animation-delay:.12s">
            <span class="export-icon">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3v12m0 0-4-4m4 4 4-4M5 21h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>
                <b>Exportar endereços</b>
                <small>Baixe seus dados em formato CSV.</small>
            </span>
            <svg class="export-arrow" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m9 18 6-6-6-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
    </aside>
</div>
